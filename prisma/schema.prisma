/**
 * Prisma Schema
 *
 * Database: PostgreSQL (Supabase)
 * ORM: Prisma 7
 *
 * Models:
 * - Grade        → represents a grade level (e.g. Grade 4); created by dev/admin only
 * - Section      → a named group of students under a grade (e.g. "Ichigo"); created by dev/admin only
 * - Teacher      → manages classrooms and lessons; can have admin privileges
 * - Student      → belongs to one section; tracks progress through lessons
 * - Subject      → predetermined by the system; seeded by dev; Math is unlocked, others locked
 * - ClassRoom    → links a teacher, subject, and section; teacher self-assigns
 * - Lesson       → individual learning unit under a classroom, stored as canvas JSON
 * - Template     → reusable canvas layout, owned by a teacher
 * - Badge        → milestone rewards defined by the system
 * - Progress     → tracks student completion and score per lesson
 * - StudentBadge → tracks which student earned which badge
 *
 * Changes from previous schema:
 * - Grade model added — parent of Section; dev/admin only
 * - Section model added — replaces direct grade field on Student
 * - ClassRoom model added — links Teacher + Subject + Section; replaces Subject ownership by teacher
 * - Subject redesigned — no longer owned by a teacher; seeded by dev; isLocked controls access
 * - Lesson moved — now belongs to ClassRoom instead of Subject
 * - Student.sectionId added — every student belongs to exactly one section
 * - Enrollment model removed — section membership replaces individual enrollment
 * - Teacher.subjects relation removed — teachers no longer own subjects directly
 *
 * Admin access is a privilege, not a separate role.
 * Teachers with isAdmin: true are granted elevated access by the dev directly in the database.
 * isAdmin is carried in the JWT and checked by middleware on protected routes.
 *
 * Subject list (seeded, not user-created):
 * - Mathematics         → unlocked
 * - Science             → locked (Grade 3+, future)
 * - English             → locked
 * - Filipino            → locked
 * - Araling Panlipunan  → locked
 * - GMRC/Values Ed      → locked
 * - MAPEH               → locked
 *
 * Model ordering follows the dependency chain:
 *   Independent models first → dependent models next → junction tables last
 *
 * IDs use auto increment integers for simplicity and easier debugging.
 * Foreign keys use Int to match.
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Independent Models ─────────────────────────────────────────────────────

// Grade levels (e.g. Grade 4, Grade 5, Grade 6).
// Created by dev/admin only — never by teachers or students.
// Sections live under a grade.
model Grade {
  id        Int       @id @default(autoincrement())
  level     Int       @unique // e.g. 4, 5, 6
  sections  Section[]
  createdAt DateTime  @default(now())
}

// A named group of students under a grade (e.g. "Ichigo" under Grade 4).
// Created by dev/admin only.
// Students pick their section during registration.
// ClassRooms are linked to sections when a teacher self-assigns.
model Section {
  id         Int        @id @default(autoincrement())
  name       String     // e.g. "Ichigo", "Naruto", "Luffy"
  grade      Grade      @relation(fields: [gradeId], references: [id])
  gradeId    Int
  students   Student[]
  classRooms ClassRoom[]
  createdAt  DateTime   @default(now())

  @@unique([gradeId, name]) // no duplicate section names within the same grade
}

model Teacher {
  id         Int         @id @default(autoincrement())
  name       String
  email      String      @unique
  password   String      // stored as bcrypt hash, never plain text
  isAdmin    Boolean     @default(false) // privilege flag — granted by dev directly in the database
  classRooms ClassRoom[]
  templates  Template[]
  createdAt  DateTime    @default(now())
}

model Student {
  id        Int            @id @default(autoincrement())
  name      String
  lrn       String         @unique // 12-digit Learner Reference Number, stored as string
  email     String         @unique
  password  String         // stored as bcrypt hash, never plain text
  xp        Int            @default(0) // total experience points earned
  level     Int            @default(1) // level up every 100 XP
  section   Section        @relation(fields: [sectionId], references: [id])
  sectionId Int            // every student belongs to exactly one section
  progress  Progress[]
  badges    StudentBadge[]
  createdAt DateTime       @default(now())
}

// Predetermined by the system — never created by teachers.
// Seeded by dev via prisma/seed.ts.
// isLocked controls whether teachers can create classrooms under this subject.
// Only Mathematics is unlocked for the prototype.
model Subject {
  id         Int         @id @default(autoincrement())
  name       String      @unique // e.g. "Mathematics", "Science"
  description String
  isLocked   Boolean     @default(true) // false = Math only for now
  classRooms ClassRoom[]
  createdAt  DateTime    @default(now())
}

model Badge {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  description String
  xpRequired  Int            // minimum XP needed to earn this badge
  students    StudentBadge[]
  createdAt   DateTime       @default(now())
}

// ── Dependent Models ───────────────────────────────────────────────────────

// Links a teacher, subject, and section together.
// Created when a teacher self-assigns to teach a subject to a section.
// One teacher per subject per section — enforced by unique constraint.
// Lessons live under a classroom, not directly under a subject.
model ClassRoom {
  id        Int       @id @default(autoincrement())
  teacher   Teacher   @relation(fields: [teacherId], references: [id])
  teacherId Int
  subject   Subject   @relation(fields: [subjectId], references: [id])
  subjectId Int
  section   Section   @relation(fields: [sectionId], references: [id])
  sectionId Int
  lessons   Lesson[]
  createdAt DateTime  @default(now())

  @@unique([teacherId, subjectId, sectionId]) // one teacher per subject per section
}

// Individual learning unit under a classroom, stored as canvas JSON.
// contentJson is nullable — a lesson can exist with no content yet (blank canvas).
// updatedAt tracks the last save, used for optimistic save feedback in the editor.
//
// Canvas JSON shape:
//   {
//     "canvas": { "width": 1280, "height": 720, "background": "#ffffff" },
//     "elements": [
//       { "id": "el_1", "type": "text" | "image" | "shape",
//         "x": 100, "y": 80, "width": 300, "height": 80, "props": { ... } }
//     ]
//   }
model Lesson {
  id          Int       @id @default(autoincrement())
  title       String
  contentJson Json?     // canvas JSON — null means blank canvas
  classRoom   ClassRoom @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  classRoomId Int
  progress    Progress[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Reusable canvas layouts created and owned by teachers.
// isPublic controls visibility in the global template library.
// usageCount increments each time a teacher duplicates this template into a lesson.
// teacherId is nullable to handle teacher deletion gracefully (SetNull on delete).
model Template {
  id          Int      @id @default(autoincrement())
  title       String
  contentJson Json
  isPublic    Boolean  @default(false)
  usageCount  Int      @default(0)
  teacher     Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  teacherId   Int?     // null if the owning teacher was deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Junction Tables ────────────────────────────────────────────────────────

// Tracks student completion and score per lesson.
model Progress {
  id        Int      @id @default(autoincrement())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId Int
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  Int
  completed Boolean  @default(false)
  score     Int?     // optional — not all lessons have scores
  xpEarned  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([studentId, lessonId]) // prevent duplicate progress entries
}

// Tracks which student earned which badge and when.
model StudentBadge {
  id        Int      @id @default(autoincrement())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId Int
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  badgeId   Int
  earnedAt  DateTime @default(now())

  @@unique([studentId, badgeId]) // a student can only earn each badge once
}