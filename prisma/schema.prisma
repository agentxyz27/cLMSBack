/**
 * Prisma Schema
 *
 * Database: PostgreSQL (Supabase)
 * ORM: Prisma 7
 *
 * Models:
 * - Teacher      → creates and manages subjects and lessons
 * - Student      → enrolls and tracks progress through lessons
 * - Admin        → manages templates and oversees the system
 * - Badge        → milestone rewards defined by the system
 * - Subject      → a course owned by a teacher, contains lessons
 * - Lesson       → individual learning unit under a subject, stored as canvas JSON
 * - Template     → reusable canvas layout, owned by a teacher or admin
 * - Progress     → tracks student completion and score per lesson
 * - StudentBadge → tracks which student earned which badge
 * - Enrollment   → tracks which student is enrolled in which subject
 *
 * Changes from previous schema:
 * - LessonBlock model removed — lessons now store content as canvas JSON
 * - Lesson.contentJson added — replaces the blocks relation
 * - Lesson.updatedAt added — needed for save tracking
 * - Admin model added — standalone role for template curation and system management
 * - Template model added — reusable canvas layouts, ownable by teacher or admin
 *
 * Template ownership uses two nullable FKs (teacherId, adminId).
 * Exactly one must be set. Enforced at the application layer.
 *
 * Model ordering follows the dependency chain:
 *   Independent models first → dependent models next → junction tables last
 *
 * IDs use auto increment integers for simplicity and easier debugging.
 * Foreign keys use Int to match.
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Independent Models ─────────────────────────────────────────────────────

model Teacher {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String     // stored as bcrypt hash, never plain text
  subjects  Subject[]
  templates Template[] // templates created by this teacher
  createdAt DateTime   @default(now())
}

model Student {
  id          Int            @id @default(autoincrement())
  name        String
  lrn         String         @unique // 12-digit Learner Reference Number, stored as string
  email       String         @unique
  password    String         // stored as bcrypt hash, never plain text
  xp          Int            @default(0) // total experience points earned
  level       Int            @default(1) // level up every 100 XP
  progress    Progress[]
  badges      StudentBadge[]
  enrollments Enrollment[]
  createdAt   DateTime       @default(now())
}

// Admins manage the global template pool and can oversee lessons/subjects.
// Separate model from Teacher and Student — not a flag on an existing model.
// Admins do not enroll, do not earn XP, and do not own subjects.
model Admin {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String     // stored as bcrypt hash, never plain text
  templates Template[] // templates created by this admin
  createdAt DateTime   @default(now())
}

model Badge {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  description String
  xpRequired  Int            // minimum XP needed to earn this badge
  students    StudentBadge[]
  createdAt   DateTime       @default(now())
}

// ── Dependent Models ───────────────────────────────────────────────────────

model Subject {
  id          Int          @id @default(autoincrement())
  title       String
  teacher     Teacher      @relation(fields: [teacherId], references: [id])
  teacherId   Int          // foreign key — links subject to its owner teacher
  lessons     Lesson[]
  enrollments Enrollment[]
  createdAt   DateTime     @default(now())
}

// Lessons now store content as a single canvas JSON blob.
// The canvas JSON shape is:
//
//   {
//     "canvas": {
//       "width": 1280,
//       "height": 720,
//       "background": "#ffffff"
//     },
//     "elements": [
//       {
//         "id": "el_1",
//         "type": "text" | "image" | "shape",
//         "x": 100,
//         "y": 80,
//         "width": 300,
//         "height": 80,
//         "props": { ... }
//       }
//     ]
//   }
//
// contentJson is nullable — a lesson can exist with no content yet (blank canvas).
// updatedAt tracks the last save, used for optimistic save feedback in the editor.
model Lesson {
  id          Int        @id @default(autoincrement())
  title       String
  contentJson Json?      // canvas JSON — null means blank canvas
  subject     Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId   Int        // foreign key — links lesson to its parent subject
  progress    Progress[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt // auto-updated on every save
}

// Reusable canvas layouts that teachers or admins can publish globally.
// Ownership is polymorphic via two nullable FKs — exactly one must be non-null.
// This is enforced at the application layer, not the DB layer.
//
// isPublic controls visibility in the global template library.
// usageCount increments each time a teacher duplicates this template into a lesson.
//
// Ownership rules:
//   - teacherId set, adminId null  → owned by a teacher
//   - adminId set, teacherId null  → owned by an admin
//   - both null or both set        → invalid, rejected by application layer
model Template {
  id          Int      @id @default(autoincrement())
  title       String
  contentJson Json     // canvas JSON — templates must always have content
  isPublic    Boolean  @default(false) // false = draft, true = visible in global library
  usageCount  Int      @default(0)     // incremented on each duplication

  // Nullable FK pair — exactly one is set
  teacher     Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  teacherId   Int?     // set if owned by a teacher, null if owned by admin
  admin       Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  adminId     Int?     // set if owned by an admin, null if owned by teacher

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Junction Tables ────────────────────────────────────────────────────────

model Progress {
  id        Int      @id @default(autoincrement())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId Int      // foreign key — which student
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  Int      // foreign key — which lesson
  completed Boolean  @default(false)
  score     Int?     // optional — not all lessons have scores
  xpEarned  Int      @default(0) // XP awarded for completing this lesson
  createdAt DateTime @default(now())
}

// Tracks which student earned which badge and when
model StudentBadge {
  id        Int      @id @default(autoincrement())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId Int
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  badgeId   Int
  earnedAt  DateTime @default(now())
}

// Tracks which student is enrolled in which subject
model Enrollment {
  id         Int      @id @default(autoincrement())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId  Int
  subject    Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId  Int
  enrolledAt DateTime @default(now())

  @@unique([studentId, subjectId]) // prevent duplicate enrollments
}